  "rules": [
    {
      "id": "rule-email-warmup-throttle",
      "name": "Throttle email edges to warmup ceiling",
      "edgeId": "*-to-email",
      "evaluateAt": "before-action",
      "condition": {
        "email.warmup.currentDailyCeiling": {
          "$exists": true
        }
      },
      "outcome": {
        "action": "throttle",
        "params": {
          "source": "email.warmup.currentDailyCeiling"
        }
      },
      "enabled": true
    },
    {
      "id": "rule-skip-dunning-if-paid",
      "name": "Skip dunning if payment received within 24h",
      "edgeId": "bridge-11",
      "evaluateAt": "before-action",
      "condition": {
        "invoice.lastPaymentWithin24h": true
      },
      "outcome": {
        "action": "skip"
      },
      "enabled": true
    },
    {
      "id": "rule-critical-bridge-alert",
      "name": "Alert operator on critical bridge failure",
      "edgeId": "*-critical",
      "evaluateAt": "on-error",
      "condition": {
        "edge.critical": true
      },
      "outcome": {
        "action": "alert",
        "params": {
          "channel": "email",
          "severity": "high"
        }
      },
      "enabled": true
    }
  ],
