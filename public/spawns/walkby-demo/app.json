<p className=\"mt-1 text-xs text-neutral-500\">· check</p>\n      </div>\n        </div>\n      </section>\n\n      <section aria-label=\"This week\">\n        <div className=\"grid grid-cols-1 gap-4 lg:grid-cols-3\">\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Fulfillment queue</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">14 orders awaiting label · 2 need address verification.</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Inventory alerts</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Ember Red Dutch Oven: 4 left · Espresso Roast 1kg: 7 left.</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Abandoned carts</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">23 open · wire the 24h recovery email to hit 8 with coupon.</p>\n      </article>\n        </div>\n      </section>\n\n      <section aria-label=\"Recent activity\">\n        <h2 className=\"text-sm font-medium uppercase tracking-[0.14em] text-neutral-500\">Recent activity</h2>\n        <ul className=\"mt-3 rounded-2xl border border-neutral-200 bg-white divide-y divide-neutral-100\">\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Order #10482</span>\n            <span className=\"text-neutral-600\"> 1× Discovery Box — &#36;24.99 to Berlin</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">just now</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Order #10481</span>\n            <span className=\"text-neutral-600\"> 2× Cast Iron Skillet — &#36;99.98 to Tbilisi</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">8m ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Shippo</span>\n            <span className=\"text-neutral-600\"> label printed for #10479 (FedEx 2-Day)</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">15m ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Klaviyo</span>\n            <span className=\"text-neutral-600\"> abandoned-cart email sent to 8 customers</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">42m ago</span>\n        </li>\n        </ul>\n      </section>\n    </div>\n  );\n}\n"
