          "componentSource": "// Generated by admin-spawn — /dashboard landing.\n// Vertical-specific KPI + activity layout driven by\n// src/lib/app/dashboard-by-vertical.ts at spawn time.\nexport default function DashboardPage() {\n  return (\n    <div className=\"mx-auto max-w-6xl space-y-10\">\n      <header>\n        <h1 className=\"text-3xl font-semibold tracking-tight text-neutral-900\">Crema Lab v7 — revenue + usage</h1>\n        <p className=\"mt-2 text-neutral-600\">Subscription health at a glance.</p>\n      </header>\n\n      <section aria-label=\"Key metrics\">\n        <div className=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">MRR</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">&#36;12,480</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ +8.2%</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">Active accounts</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">284</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ +14</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">Churn (30d)</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">2.1%</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ -0.4pt</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">Activation rate</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">61%</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ +3pt</p>\n      </div>\n        </div>\n      </section>\n\n      <section aria-label=\"This week\">\n        <div className=\"grid grid-cols-1 gap-4 lg:grid-cols-3\">\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Billing this week</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Incoming invoices: 47 · Past due: 2 · Refunds: 1.</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Product funnel</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Signup → Activated → Subscribed. Wire Mixpanel to populate.</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Team</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Invite teammates to Business, Billing, Owner roles.</p>\n      </article>\n        </div>\n      </section>\n\n      <section aria-label=\"Recent activity\">\n        <h2 className=\"text-sm font-medium uppercase tracking-[0.14em] text-neutral-500\">Recent activity</h2>\n        <ul className=\"mt-3 rounded-2xl border border-neutral-200 bg-white divide-y divide-neutral-100\">\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Alex Chen</span>\n            <span className=\"text-neutral-600\"> upgraded from Starter → Pro</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">just now</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Morgan</span>\n            <span className=\"text-neutral-600\"> completed onboarding milestone 4</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">12m ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">System</span>\n            <span className=\"text-neutral-600\"> monthly invoice run queued 47 charges</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">1h ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Jamie Ray</span>\n            <span className=\"text-neutral-600\"> added 3 seats to account</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">yesterday</span>\n        </li>\n        </ul>\n      </section>\n    </div>\n  );\n}\n"
