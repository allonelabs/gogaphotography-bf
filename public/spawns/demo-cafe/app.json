          "componentSource": "// Generated by admin-spawn — /dashboard landing.\n// Vertical-specific KPI + activity layout driven by\n// src/lib/app/dashboard-by-vertical.ts at spawn time.\nexport default function DashboardPage() {\n  return (\n    <div className=\"mx-auto max-w-6xl space-y-10\">\n      <header>\n        <h1 className=\"text-3xl font-semibold tracking-tight text-neutral-900\">Demo Cafe — reservations + service</h1>\n        <p className=\"mt-2 text-neutral-600\">Tonight + this week at a glance.</p>\n      </header>\n\n      <section aria-label=\"Key metrics\">\n        <div className=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">Tonight</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">38 covers</p>\n        <p className=\"mt-1 text-xs text-neutral-500\">· 4 open tables</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">This week</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">214</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ +22 vs last</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">No-show rate</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">4.2%</p>\n        <p className=\"mt-1 text-xs text-emerald-600\">↑ -1.1pt</p>\n      </div>\n      <div className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <p className=\"text-[0.7rem] font-medium uppercase tracking-[0.12em] text-neutral-500\">Avg party size</p>\n        <p className=\"mt-2 text-2xl font-semibold text-neutral-900\">2.8</p>\n        <p className=\"mt-1 text-xs text-neutral-500\">· steady</p>\n      </div>\n        </div>\n      </section>\n\n      <section aria-label=\"This week\">\n        <div className=\"grid grid-cols-1 gap-4 lg:grid-cols-3\">\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Tonight's service</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Peak: 8-9pm · VIPs: Mira Chen (tasting menu), table 4.</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Menu performance</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Top-ordered this week: Hand-rolled pappardelle (41) · Duck ragù (34).</p>\n      </article>\n      <article className=\"rounded-2xl border border-neutral-200 bg-white p-5\">\n        <h3 className=\"text-sm font-medium text-neutral-900\">Staff</h3>\n        <p className=\"mt-2 text-sm leading-relaxed text-neutral-600\">Tonight: 3 FOH, 4 BOH · Tomorrow opens at 12, short-staffed 1.</p>\n      </article>\n        </div>\n      </section>\n\n      <section aria-label=\"Recent activity\">\n        <h2 className=\"text-sm font-medium uppercase tracking-[0.14em] text-neutral-500\">Recent activity</h2>\n        <ul className=\"mt-3 rounded-2xl border border-neutral-200 bg-white divide-y divide-neutral-100\">\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">OpenTable</span>\n            <span className=\"text-neutral-600\"> new reservation — 2 guests, Saturday 7:30pm</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">just now</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Table 12</span>\n            <span className=\"text-neutral-600\"> requested the wine list refill</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">10m ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Supplier</span>\n            <span className=\"text-neutral-600\"> produce delivery confirmed for 10am tomorrow</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">45m ago</span>\n        </li>\n        <li className=\"flex items-start gap-3 py-3 border-b border-neutral-100 last:border-0\">\n          <span className=\"mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400 flex-shrink-0\" aria-hidden=\"true\" />\n          <div className=\"flex-1 text-sm\">\n            <span className=\"text-neutral-900 font-medium\">Square</span>\n            <span className=\"text-neutral-600\"> end-of-day close — &#36;4,820 gross</span>\n          </div>\n          <span className=\"text-xs text-neutral-500 flex-shrink-0\">yesterday</span>\n        </li>\n        </ul>\n      </section>\n    </div>\n  );\n}\n"
